-- Helper function to set highlight groups
local function hi(group, opts)
  local cmd = "hi " .. group
  if opts.fg then
    cmd = cmd .. " guifg=" .. opts.fg
  end
  if opts.bg then
    cmd = cmd .. " guibg=" .. opts.bg
  end
  if opts.gui then
    cmd = cmd .. " gui=" .. opts.gui
  end
  if opts.sp then
    cmd = cmd .. " guisp=" .. opts.sp
  end
  vim.cmd(cmd)
end

-- Main highlight groups
hi("Normal", { fg = colors.white, bg = colors.black })

-- UI Elements
hi("CurSearch", { fg = colors.white, bg = dimviol })
hi("Directory", { fg = lightviol })
