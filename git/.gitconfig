[user]
    name = Lima, Jose
    email = 20385388+ono7@users.noreply.github.com
  	signingkey = 850FAC73

[gpg]
  program = gpg

[commit]
	gpgsign = true

[tag]
  gpgsign = true
  sort = -taggerdate

[core]
  editor = nvim
  mergeoptions = --no-edit
	pager = delta
  hookspath = ~/.git_global/hooks
  compression = 9
  whitespace = error
  preloadindex = true
  # MONITOR FOR PERFORMANCE ISSUES....
  # check status: git fsmonitor--daemon status
	untrackedCache = true
	excludesfile = /Users/jlima/.gitignore_global
  # fsmonitor = true

[http]
  sslVerify = false

[url "https://github.com/"]
  insteadOf = git://github.com/

[credential]
  helper = store

[init]
  defaultBranch = main
  templatedir = ~/.git_templates

[pull]
# requires git > 2.6
# `git rebase –abort` when we need to reset the changes
  default = current
  rebase = true

[rebase]
  # Stash and pop uncommitted changes on rebase
  autostash = true
  missingCommitCheck = warn
  autosquash = true
  updateRefs = true

[fetch]
  prune = true
  prunetags = true
  fsckobjects = true

[transfer]
  fsckobjects = true

[receive]
  fsckobjects = true

[branch]
  sort = -committerdate

[merge]
  tool = nvimdiff4
  prompt = false
  conflictstyle = diff3

[mergetool "nvimdiff4"]
  cmd = nvim -d $LOCAL $BASE $REMOTE $MERGED -c '$wincmd w' -c 'wincmd J'

[mergetool]
  keepBackup = false
  prompt = false

[push]
  autoSetupRemote = true
  default = current
 # create tags automatically
  followTags = true

  # push only the default branch
  ; default = simple

[diff]
	colorMoved = default
  algorithm = patience
  context = 4
  renames = copies
  interHunkContext = 10

[color]
  ui = auto

[alias]
  co = checkout
  br = branch
  ci = commit
  st = status
  wt = worktree
  unstage = reset HEAD --
  last = log -1 HEAD
  dv = "! args=$@; shift $#; nvim -c \"DiffviewOpen $args\""
  update-hooks = !cp -R ~/.git_templates/hooks/. .git/hooks/ && chmod +x .git/hooks/*
	whatadded = log --diff-filter=A

[log]
# follow file names in `git log` command even if they are renamed
follow = true

[interactive]
	diffFilter = delta --color-only
  singleKey = true

[status]
  # Show untracked files, directories and files in untracked directories
  branch = true
  showStash = true
  showUntrackedFiles = all
  submoduleSummary = true

[delta]
    navigate = true
    light = false
    side-by-side = true
    line-numbers = true
    dark = true
    blame-palette = "#1D2433 #2D3343 #3E485A #364156 #424B5D"
    commit-decoration-style = none
    file-decoration-style = none
    file-style = "#E3DED7"
    hunk-header-decoration-style = none
    hunk-header-file-style = bold
    hunk-header-line-number-style = bold "#A6B0C3"
    hunk-header-style = file line-number syntax
    
    # Standard line number styling
    line-numbers-left-style = "#8087a2"
    line-numbers-right-style = "#8087a2"
    line-numbers-zero-style = "#8087a2"
    
    # Much brighter line numbers for deleted/added lines
    line-numbers-minus-style = "#FF9999"
    line-numbers-plus-style = "#99FF99"
    
    # Subtle coloring for added/deleted lines, but not too prominent
    minus-style = "#D5AFAF"
    plus-style = "#A2CFBF"
    
    # Yellow background with black text ONLY for changed parts
    minus-emph-style = "#171F2C #D4B97E"
    plus-emph-style = "#171F2C #D4B97E"
    
    # Increase word diff detection to catch more changes
    word-diff-regex = "[^[:space:]]+"
    
    whitespace-error-style = "#D4B97E" reverse
    line-numbers-left-format = "{nm:>4}│"
    line-numbers-right-format = "{np:>4}│"
    map-styles = \
        bold purple => "#3E3A47", \
        bold blue => "#344054", \
        bold cyan => "#394A49", \
        bold yellow => "#4A4335"
[rerere]
	enabled = true
