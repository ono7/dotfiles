[user]
    name = jlima
    email = jlima@mbp

[includeIf "gitdir:~/work/**"]
  path = .gitconfig-work

[includeIf "gitdir:~/git.marriott.com/**"]
  path = .gitconfig-work

[core]
  editor = nvim
  mergeoptions = --no-edit

[http]
  sslVerify = false

[url "https://github.com/"]
  insteadOf = git://github.com/

[credential]
  helper = store

[init]
  defaultBranch = main
  templatedir = ~/.git_templates

[pull]
# requires git > 2.6
# `git rebase –abort` when we need to reset the changes
  rebase = true

[fetch]
  prune = true

[merge]
  tool = nvimdiff4
  prompt = false

[mergetool "nvimdiff4"]
  cmd = nvim -d $LOCAL $BASE $REMOTE $MERGED -c '$wincmd w' -c 'wincmd J'

[mergetool]
  keepBackup = false
  prompt = false

[push]
  autoSetupRemote = true

# push only the default branch
  default = simple

[diff]
  colorMoved = zebra
  algorithm = patience

[color]
  ui = auto

[color "diff"]
    meta = normal
    frag = normal
    func = normal
    old = red normal
    new = green normal
    commit = yellow normal
    whitespace = normal red
    oldMoved = magenta
    newMoved = cyan

[color "diff-highlight"]
    oldNormal = red normal
    oldHighlight = red normal
    newNormal = green normal
    newHighlight = green normal
    oldMovedAlternative = magenta
    newMovedAlternative = cyan

[alias]
  co = checkout
  br = branch
  ci = commit
  st = status
  wt = worktree
  unstage = reset HEAD --
  last = log -1 HEAD
  dv = "! args=$@; shift $#; nvim -c \"DiffviewOpen $args\""
